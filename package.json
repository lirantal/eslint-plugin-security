{
  "name": "eslint-plugin-security",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Liran Tal",
    "email": "liran.tal@gmail.com",
    "url": "https://github.com/lirantal"
  },
  "scripts": {
    "lerna": "lerna",
    "lint": "echo \"No lint step configured\"",
    "build": "echo \"No build step configured\"",
    "test": "echo \"No test step configured\"",
    "lint:markdown": "markdownlint -c .github/.markdownlint.yml '**/**.md'",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lirantal/eslint-plugin-security.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "lerna": "^9.0.7",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lint-staged": "^17.0.7",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "markdownlint-cli": "0.49.0"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint --env HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged",
      "post-merge": "yarn install",
      "pre-push": "lerna run lint && lerna run test"
    }
  },
  "lint-staged": {
    "linters": {
      "**/*.js": [
        "prettier-standard",
        "eslint",
        "git add"
      ]
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.10.0"
  }
}
